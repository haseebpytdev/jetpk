APP_NAME="Asif Travels"
APP_ENV=staging
APP_KEY=
APP_DEBUG=false
APP_URL=https://ota.haseebasif.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

OTA_DEFAULT_AGENCY_SLUG=asif-travels
# Live public document root for client-assets/themes disk checks (diagnostics). Falls back to Laravel public/ when missing.
# OTA_PUBLIC_WEBROOT_PATH=/home/u654883295/domains/haseebasif.com/public_html/ota.haseebasif.com
# Daily A3 agency booking activity summary scheduler (routes/console.php 07:10; no --force)
AGENCY_BOOKING_ACTIVITY_SUMMARY_DAILY_ENABLED=true

OTA_GUEST_LOOKUP_TOKEN_MINUTES=30
OTA_SUPPLIER_DEFAULT_PROVIDER=duffel
OTA_SUPPLIER_TIMEOUT_SECONDS=20
# Public flight results allowlist (supplier_provider values kept outside testing)
OTA_PUBLIC_FLIGHT_RESULTS_SUPPLIERS=duffel,sabre,iati,pia_ndc
# Local-only: unsafe cached-pricing checkout fallback when live validation fails (never enable in staging/production)
OTA_ALLOW_PROVIDER_UNSTABLE_LOCAL=false
# Airline logos on results: local file (airlines.logo_path) first; else public CDN (2-letter IATA)
OTA_AIRLINE_LOGO_CDN_ENABLED=true
# OTA_AIRLINE_LOGO_CDN_TEMPLATE=https://images.kiwi.com/airlines/64x64/{CODE}.png
DUFFEL_API_VERSION=v2
DUFFEL_DEFAULT_BASE_URL=https://api.duffel.com
# Duffel access tokens belong in Admin → Supplier API settings (encrypted), not in this file.
# Al-Haider Umrah group packages (read-only; credentials never committed)
ALHAIDER_API_ENABLED=false
ALHAIDER_API_BASE_URL=https://alhaidertravel.pk
ALHAIDER_API_USERNAME=
ALHAIDER_API_PASSWORD=
# Optional static bearer token (skips login when set)
ALHAIDER_API_TOKEN=
ALHAIDER_API_TIMEOUT=20
ALHAIDER_CACHE_TTL_SECONDS=600
ALHAIDER_BOOKING_ENABLED=false
ALHAIDER_RESERVE_PATH=/api/group/reserve
ALHAIDER_CANCEL_PATH=/api/group/cancel

# Group ticketing reservation hold (minutes)
OTA_GROUP_BOOKING_HOLD_MINUTES=25
OTA_GROUP_INVENTORY_SEARCH_SYNC_ENABLED=true
OTA_GROUP_INVENTORY_SEARCH_SYNC_STALE_MINUTES=3
OTA_GROUP_REALTIME_SEARCH_ENABLED=true
OTA_GROUP_REALTIME_SEARCH_TTL_SECONDS=0
OTA_GROUP_REQUIRE_LIVE_PROVIDER_FOR_PUBLIC_RESULTS=true
OTA_GROUP_ALLOW_STALE_PUBLIC_RESULTS=false
OTA_GROUP_REQUIRE_LIVE_PROVIDER_FOR_RESERVATION=true
OTA_GROUP_BLOCK_BOOKING_WHEN_PROVIDER_UNAVAILABLE=true
# F9P: final controlled PNR retry freshness window (minutes; independent of F9M stale lane)
OTA_CONTROLLED_FINAL_PNR_FRESHNESS_MAX_MINUTES=15
# F9O-R1: max minutes after F9N fresh context for strong-linkage apply
OTA_CONTROLLED_STRONG_LINKAGE_APPLY_MAX_MINUTES=180
# Sabre HTTP timeouts (shop search, token, revalidate, booking). duration_ms ~10s with http_status=null usually means connect timeout.
SABRE_TIMEOUT_SECONDS=30
SABRE_CONNECT_TIMEOUT_SECONDS=25
# BF2: optional BFM v4 BrandedFareIndicators on shop requests (default false; CERT/local probe only)
SABRE_BRANDED_FARES_SEARCH_ENABLED=false
# BF5: display-only branded fare chips on search cards (no checkout selection). Default false.
SABRE_BRANDED_FARES_DISPLAY_ENABLED=false
# BF6: branded fare selection intent on results → checkout (requires DISPLAY=true). Default false.
SABRE_BRANDED_FARES_SELECTION_ENABLED=false
# BF3-CORRECTION / BF3-D / BF3-F: BrandedFareIndicators placement (current_tis_tpa | root_price_tpa | root_optional_qualifiers | iati_full_tis_tpa | iati_exact_gds_v4)
SABRE_BRANDED_FARES_REQUEST_VARIANT=current_tis_tpa
# BF3-D / BF3-F: IntelliSell RequestType for iati_full_tis_tpa (default 100ITINS) or iati_exact_gds_v4 (default 200ITINS when unset)
# SABRE_BRANDED_FARES_INTELLISELL_REQUEST_TYPE=100ITINS
# Response-side branded-fare mapping probe (metadata only; no raw payload)
# SABRE_BRANDED_FARES_PROBE_ENABLED=false
# BF7-A/B: local/test AirPrice Brand shape compare (default false; no production checkout change)
SABRE_BRANDED_FARES_AIRPRICE_BRAND_SHAPE_COMPARE_ENABLED=false
# BF7-B: compare wire variant when gate ON (current_object_code | string_array)
SABRE_BRANDED_FARES_AIRPRICE_BRAND_SHAPE_COMPARE_VARIANT=current_object_code
# Sabre booking (B10/B62): Trip Orders createBooking stays the default packaged path; Passenger Records + traditional CPNR wire
# is gated by booking_path + booking_schema together (omit schema to derive from path).
# SABRE_BOOKING_SCHEMA=create_passenger_name_record | passenger_records_create_pnr (alias of create_passenger_name_record)
#                           | trip_orders_create_booking
# Example Passenger Records tenant: SABRE_BOOKING_SCHEMA=create_passenger_name_record and
# SABRE_BOOKING_PATH=/v2.5.0/passenger/records?mode=create (or /v2.4.0/passenger/records?mode=create).
# When SABRE_BOOKING_LIVE_CALL_ENABLED=false, checkout stores a dry-run attempt and does not POST to Sabre.
SABRE_BOOKING_ENABLED=false
SABRE_BOOKING_LIVE_CALL_ENABLED=false
# R6: public checkout uses certified route selector only (no Passenger Records → v2/passengers → Trip Orders chains).
SABRE_CERTIFIED_ROUTE_SELECTOR_ENABLED=true
SABRE_TICKETING_ENABLED=false
SABRE_TICKETING_LIVE_CALL_ENABLED=false
SABRE_PUBLIC_TICKETING_ENABLED=false
SABRE_CHECKOUT_AUTO_TICKETING_ENABLED=false
# SABRE_TICKETING_PATH=/v1.3.0/air/ticket
# SABRE_TICKETING_PRINTER_COUNTRY_CODE=PK
# SABRE_TICKETING_PRINTER_LNIATA=
SABRE_TICKET_DOCUMENTS_LIVE_RETRIEVE_ENABLED=false
SABRE_VOID_ENABLED=false
SABRE_VOID_LIVE_CALL_ENABLED=false
SABRE_REFUND_ENABLED=false
SABRE_REFUND_LIVE_CALL_ENABLED=false
SABRE_NDC_ENABLED=false
SABRE_NDC_SEARCH_ENABLED=false
SABRE_NDC_ORDER_CREATE_ENABLED=false
SABRE_NDC_PUBLIC_ORDER_CREATE_ENABLED=false
SABRE_NDC_CANCEL_ENABLED=false
# BF8-A — Production operational window (post BF7-J-OPS proof; repo defaults stay false).
# Operational bundle (enable all three together for same-carrier 2-seg public auto-PNR):
#   SABRE_BOOKING_ENABLED=true
#   SABRE_BOOKING_LIVE_CALL_ENABLED=true
#   SABRE_TICKETING_ENABLED=false  (hard rule — never enable for operational PNR-only lane)
#   SABRE_CPNR_CONNECTING_SAME_CARRIER_GDS_ENABLED=true
#   SABRE_CPNR_CONNECTING_SAME_CARRIER_PUBLIC_CHECKOUT_ENABLED=true
#   SABRE_VERIFIED_MULTISEG_AUTO_PNR_ENABLED=true  (legacy name; operational auto-PNR master switch after BF7-J-OPS)
# SABRE_VERIFIED_MULTISEG_AUTO_PNR_ENABLED requires GDS + PUBLIC flags; does not require verified-route historical evidence.
# unknown_controlled_only in verified diagnostics does not block operational PNR when SabreOperationalPnrReadiness would_attempt_pnr=true.
# BF7-J-OPS: Same-carrier 2-segment connecting GDS operational PNR (all three required for public auto-PNR attempt).
# SABRE_CPNR_CONNECTING_SAME_CARRIER_GDS_ENABLED=false
# SABRE_CPNR_CONNECTING_SAME_CARRIER_PUBLIC_CHECKOUT_ENABLED=false
# SABRE_VERIFIED_MULTISEG_AUTO_PNR_ENABLED=false
# BF7-J-OPS-FIX2 / BF8-A: CERT operational window only — omit NN/WN from Passenger Records HaltOnStatus for 2-seg same-carrier create.
# SABRE_CPNR_ALLOW_NN_HALT_ON_STATUS_CERT_OPERATIONAL=false
# E5J: Soft-block public checkout for known failed / host-NOOP Sabre pre-checkout evidence (default false).
SABRE_PRECHECKOUT_KNOWN_FAILURE_SOFT_BLOCK_ENABLED=false
SABRE_BOOKING_PATH=/v1/trip/orders/createBooking
SABRE_BOOKING_SCHEMA=trip_orders_create_booking
SABRE_BOOKING_MODE=pnr_only
# B77: OW shop per segment before live Passenger Records CPNR (PNR-only + traditional wire); avoids known 0411 when inventory stale.
SABRE_PASSENGER_RECORDS_FRESH_SHOP_GUARD_BEFORE_LIVE=true
# R5: Return/multi-city Sabre PNR — keep false until certified; public checkout always defers complex itineraries.
SABRE_COMPLEX_ITINERARY_PNR_ENABLED=false
# B22/B23: Trip Orders createBooking flight product — nested under createBooking vs **wire root** (Sabre often requires flightOffer/flightDetails at JSON root).
# trip_orders_create_booking_v1_current | trip_orders_flight_offer_v1 | trip_orders_flight_details_v1 | trip_orders_flight_offer_root_v1 | trip_orders_flight_details_root_v1 | trip_orders_flight_offer_camel_v1 | trip_orders_flight_details_camel_v1 | trip_orders_flight_details_full_camel_v1 | trip_orders_flight_details_sabre_v1 | trip_orders_flight_details_sabre_agency_v1 | trip_orders_flight_details_sabre_agencyInfo_v1 | trip_orders_flight_details_sabre_agencyPhoneNumber_v1 | trip_orders_flight_details_sabre_agencyPhonesArray_v1 | trip_orders_flight_details_sabre_rootAgencyPhone_v1 | trip_orders_flight_details_sabre_phoneNumbers_v1 | trip_orders_flight_details_sabre_pos_source_phone_v1 | trip_orders_flight_details_sabre_pos_phone_v1 | trip_orders_flight_details_sabre_agency_root_camel_v1 | trip_orders_flight_details_sabre_travelAgency_v1 | trip_orders_flight_details_sabre_customerInfo_phone_v1 | trip_orders_product_array_v1
SABRE_CREATEBOOKING_PAYLOAD_STYLE=trip_orders_flight_offer_v1
# B33/B34: Sabre Trip Orders traditional booking — agency/office phone (default wire agencyContactInfo; B34 compare styles remap). Not the customer contactInfo phone. Required for live compare/send on Sabre traditional flight-details styles when empty.
SABRE_AGENCY_PHONE=
SABRE_AGENCY_PHONE_COUNTRY_CODE=PK
SABRE_AGENCY_PHONE_TYPE=AGENCY
# B37: LocationCode on traditional PNR phone-line compare styles (IATA-style; default LHE for local/testing).
SABRE_AGENCY_PHONE_LOCATION=LHE
# B36: Optional agency metadata for POS / camel agency blocks (values are never printed by inspect diagnostics).
SABRE_AGENCY_NAME=
SABRE_AGENCY_CITY=
SABRE_AGENCY_COUNTRY=PK
# Single-letter PhoneUseType on B36 POS-style payloads (default A); separate from SABRE_AGENCY_PHONE_TYPE used on B33 agencyContactInfo.
SABRE_AGENCY_POS_PHONE_USE_TYPE=A
# B26: When false (default), Trip Orders createBooking wire omits `remarks` (Sabre expects BookRemark objects, not string[]).
SABRE_CREATEBOOKING_SEND_REMARKS=false
# B38: `sabre:compare-booking-endpoints --booking={id}` prints an inspect-only matrix (legacy passenger paths + Trip Orders unless `--skip-trip-orders`). One live POST requires `--send --endpoint=/v2/passengers/create --style=traditional_pnr_create_passenger_name_record_v1` (exact pair). `sabre:inspect-booking-payload --style=traditional_pnr_create_passenger_name_record_v1 --preview-json` shows redacted CPNR-style wire.
# B61 (local/testing): When true, traditional Passenger Records CPNR `AirBook` includes `RetryRebook` + `RedisplayReservation` (string NumAttempts/WaitInterval) for host air-book experiments. Default false.
SABRE_TRADITIONAL_CPNR_AIRBOOK_RETRY_REDISPLAY=false
# B27: Trip Orders traveler passport.document_type when UI maps to passport (default PASSPORT).
SABRE_DOCUMENT_TYPE_PASSPORT_VALUE=PASSPORT
# B14/B21: Pre-booking Sabre revalidate before Trip Orders createBooking (recommended true for prod parity).
# B21: If revalidation never returns usable linkage, set SABRE_ALLOW_CREATEBOOKING_WITHOUT_REVALIDATION=true only for
# controlled tests — createBooking then proceeds with loud audit; keep SABRE_TICKETING_ENABLED=false.
# B19: Many tenants see HTTP 400 + Sabre code 27131 on `/v4/shop/flights/revalidate`; Offers revalidate (`/v4/offers/shop/revalidate`) may behave differently — use matrix commands to probe.
SABRE_REVALIDATE_PATH=/v4/offers/shop/revalidate
SABRE_REVALIDATE_BEFORE_BOOKING=true
SABRE_ALLOW_CREATEBOOKING_WITHOUT_REVALIDATION=false
# bfm_revalidate_v1 | bfm_revalidate_with_pricing_context | iati_like_bfm_revalidate_v1 (opt-in; compare via sabre:compare-revalidate-payload-coverage --fixture)
# bfm_revalidate_minimal_segments | bfm_revalidate_original_like | client_gds_revalidate_v1
SABRE_REVALIDATE_PAYLOAD_STYLE=bfm_revalidate_v1
# Sprint 0: Sabre cancel inspect/cert only (`php artisan sabre:inspect-cancel-booking`). All false by default.
SABRE_CANCEL_ENABLED=false
SABRE_CANCEL_LIVE_CALL_ENABLED=false
SABRE_ADMIN_CANCEL_LIVE_CALL_ENABLED=false
SABRE_CANCEL_REQUIRE_CONFIRMATION=true
SABRE_CANCEL_ALLOW_PRODUCTION_SEND=false
SABRE_CANCEL_ALLOW_PRODUCTION_HOST=false
SABRE_CANCEL_ENDPOINT_PATH=/v1/trip/orders/cancelBooking
# Production read-only PNR retrieve inspect (`php artisan sabre:inspect-pnr-retrieve --booking=ID --send`). No DB writes.
SABRE_PNR_RETRIEVE_INSPECT_ENABLED=false
# Sabre CERT/STL token probe (php artisan sabre:cert-token-probe --profile=...)
SABRE_CERT_AUTH_URL=https://stl.platform.sabre.com/v2/auth/token
SABRE_CERT_BASE_URL=https://api.cert.platform.sabre.com
# Profile cert_6md8 (user/EPR, secret/password, PCC/IPCC, domain default AA)
SABRE_CERT_6MD8_USER=
SABRE_CERT_6MD8_SECRET=
SABRE_CERT_6MD8_PCC=
SABRE_CERT_6MD8_DOMAIN=AA
# Profile cert_lu6k
SABRE_CERT_LU6K_USER=
SABRE_CERT_LU6K_SECRET=
SABRE_CERT_LU6K_PCC=
SABRE_CERT_LU6K_DOMAIN=AA
# Profile cert_test3
SABRE_CERT_TEST3_USER=
SABRE_CERT_TEST3_SECRET=
SABRE_CERT_TEST3_PCC=
SABRE_CERT_TEST3_DOMAIN=AA
FX_RATE_PROVIDER=frankfurter
FX_RATE_ENDPOINT=https://api.frankfurter.app/latest
FX_RATE_SECONDARY_ENDPOINT=https://open.er-api.com/v6/latest
FX_RATE_TIMEOUT_SECONDS=5
FX_RATE_CACHE_TTL_SECONDS=900
OTA_PRIVATE_DOCUMENTS_DIRECTORY=app/private
OTA_PDF_TEMP_DIRECTORY=app/private/tmp/pdf
OTA_BACKUP_DISK=local
OTA_BACKUP_PATH=backups
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI="${APP_URL}/auth/facebook/callback"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Privileged login security notifications (email via OtaNotificationService)
NOTIFY_CUSTOMER_LOGIN=false
NOTIFY_AGENT_LOGIN=false
NOTIFY_STAFF_LOGIN=true
NOTIFY_ADMIN_LOGIN=true
NOTIFY_FAILED_ADMIN_LOGIN=true
NOTIFY_FAILED_LOGIN=true
AUTH_FAILED_LOGIN_EMAIL_THRESHOLD=3
AUTH_FAILED_LOGIN_EMAIL_COOLDOWN_MINUTES=60
AUTH_LOGIN_SUCCESS_EMAIL_COOLDOWN_MINUTES=15
NOTIFY_AUTH_NEW_DEVICE_LOGIN=true
AUTH_NEW_DEVICE_EMAIL_COOLDOWN_MINUTES=60

# Developer control panel (product owner / deployer only — database users via dev-cp:user)
OTA_DEVELOPER_CP_ENABLED=false

# UI version channels (site / admin / staff) — v1 = current canonical views
OTA_UI_SITE_DEFAULT=v1
OTA_UI_SITE_PREVIEW_ENABLED=true
OTA_UI_ADMIN_DEFAULT=v1
OTA_UI_ADMIN_PREVIEW_ENABLED=true
OTA_UI_STAFF_DEFAULT=v1
OTA_UI_STAFF_PREVIEW_ENABLED=true

# Layered UI overrides — named CSS/JS layers after base assets (config/ui-layers.php)
OTA_UI_LAYERS_ENABLED=true
# Per-layer override example: OTA_UI_LAYER_EXAMPLE_PUBLIC_SHELL=false

# Client UI v2 preview lane (V2-MC-0) — v1 remains default; /v2 is protected preview namespace
CLIENT_UI_VERSIONING_ENABLED=true
CLIENT_UI_DEFAULT_VERSION=v1
CLIENT_UI_MASTER_SLUG=haseeb-master
CLIENT_UI_PREVIEW_ENABLED=true
CLIENT_UI_FORCE_V1_DEFAULT=true
CLIENT_UI_PREVIEW_NAMESPACE_ENABLED=true
CLIENT_UI_PREVIEW_NAMESPACE=v2
CLIENT_UI_PREVIEW_PROTECTION_ENABLED=true
CLIENT_UI_PREVIEW_KEY=
CLIENT_UI_PRESERVE_PREVIEW_NAMESPACE_LINKS=true

# Cloudflare Turnstile (public forms — registration, login, support, etc.)
TURNSTILE_ENABLED=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# JetPK local/demo fixed OTP (APP_ENV=local|testing only; ignored in production)
# OTP_DEMO_FIXED_ENABLED=false
# OTP_DEMO_FIXED_CODE=123456
# OTP_DEMO_ALLOWED_EMAILS=admin@ota.demo,staff@ota.demo,agent@ota.demo,customer@ota.demo
# OTP_DEMO_ALLOW_DEVCP=true
