APP_NAME="Asif Travels"
APP_ENV=staging
APP_KEY=
APP_DEBUG=false
APP_URL=https://ota.haseebasif.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="Asif Travels"

OTA_DEFAULT_AGENCY_SLUG=asif-travels
# Daily A3 agency booking activity summary scheduler (routes/console.php 07:10; no --force)
AGENCY_BOOKING_ACTIVITY_SUMMARY_DAILY_ENABLED=true
OTA_GUEST_LOOKUP_TOKEN_MINUTES=30
OTA_SUPPLIER_DEFAULT_PROVIDER=duffel
OTA_SUPPLIER_TIMEOUT_SECONDS=20
# Public flight results allowlist (supplier_provider values kept outside testing)
OTA_PUBLIC_FLIGHT_RESULTS_SUPPLIERS=duffel,sabre,iati,pia_ndc
FX_RATE_PROVIDER=frankfurter
FX_RATE_ENDPOINT=https://api.frankfurter.app/latest
FX_RATE_SECONDARY_ENDPOINT=https://open.er-api.com/v6/latest
FX_RATE_TIMEOUT_SECONDS=5
FX_RATE_CACHE_TTL_SECONDS=900
DUFFEL_DEFAULT_BASE_URL=https://api.duffel.com
DUFFEL_API_VERSION=v2
# Duffel access token must be configured in Admin -> API Settings (not in env/repo).
# Sabre booking (B10): Trip Orders createBooking recommended; SABRE_BOOKING_SCHEMA optional (derive from path if unset).
SABRE_BOOKING_ENABLED=false
SABRE_BOOKING_LIVE_CALL_ENABLED=false
SABRE_TICKETING_ENABLED=false
SABRE_TICKETING_LIVE_CALL_ENABLED=false
SABRE_PUBLIC_TICKETING_ENABLED=false
SABRE_CHECKOUT_AUTO_TICKETING_ENABLED=false
SABRE_TICKET_DOCUMENTS_LIVE_RETRIEVE_ENABLED=false
SABRE_VOID_ENABLED=false
SABRE_VOID_LIVE_CALL_ENABLED=false
SABRE_REFUND_ENABLED=false
SABRE_REFUND_LIVE_CALL_ENABLED=false
SABRE_NDC_ENABLED=false
SABRE_NDC_SEARCH_ENABLED=false
SABRE_NDC_ORDER_CREATE_ENABLED=false
SABRE_NDC_PUBLIC_ORDER_CREATE_ENABLED=false
SABRE_NDC_CANCEL_ENABLED=false
# BF8-A — Sabre operational PNR lane (post BF7-J-OPS). Template defaults false; ops enable during controlled window:
#   SABRE_BOOKING_ENABLED=true
#   SABRE_BOOKING_LIVE_CALL_ENABLED=true
#   SABRE_TICKETING_ENABLED=false
#   SABRE_CPNR_CONNECTING_SAME_CARRIER_GDS_ENABLED=true
#   SABRE_CPNR_CONNECTING_SAME_CARRIER_PUBLIC_CHECKOUT_ENABLED=true
#   SABRE_VERIFIED_MULTISEG_AUTO_PNR_ENABLED=true  (operational auto-PNR master switch; requires GDS + PUBLIC)
#   SABRE_CPNR_ALLOW_NN_HALT_ON_STATUS_CERT_OPERATIONAL=true  (CERT host only; disable after window)
SABRE_CPNR_CONNECTING_SAME_CARRIER_GDS_ENABLED=false
SABRE_CPNR_CONNECTING_SAME_CARRIER_PUBLIC_CHECKOUT_ENABLED=false
SABRE_VERIFIED_MULTISEG_AUTO_PNR_ENABLED=false
SABRE_CPNR_ALLOW_NN_HALT_ON_STATUS_CERT_OPERATIONAL=false
SABRE_CERTIFIED_ROUTE_SELECTOR_ENABLED=true
SABRE_BOOKING_PATH=/v1/trip/orders/createBooking
SABRE_BOOKING_SCHEMA=trip_orders_create_booking
SABRE_BOOKING_MODE=pnr_only
# B22/B23/B29/B30/B31: Trip Orders createBooking flight product + wire shape (nested vs root; B29 camel traveler keys; B31 sabre `passengerCode`).
# trip_orders_create_booking_v1_current | trip_orders_flight_offer_v1 | trip_orders_flight_details_v1 | trip_orders_flight_offer_root_v1 | trip_orders_flight_details_root_v1 | trip_orders_flight_offer_camel_v1 | trip_orders_flight_details_camel_v1 | trip_orders_flight_details_full_camel_v1 | trip_orders_flight_details_sabre_v1 | trip_orders_flight_details_sabre_agency_v1 | trip_orders_flight_details_sabre_agencyInfo_v1 | trip_orders_flight_details_sabre_agencyPhoneNumber_v1 | trip_orders_flight_details_sabre_agencyPhonesArray_v1 | trip_orders_flight_details_sabre_rootAgencyPhone_v1 | trip_orders_flight_details_sabre_phoneNumbers_v1 | trip_orders_flight_details_sabre_pos_source_phone_v1 | trip_orders_flight_details_sabre_pos_phone_v1 | trip_orders_flight_details_sabre_agency_root_camel_v1 | trip_orders_flight_details_sabre_travelAgency_v1 | trip_orders_flight_details_sabre_customerInfo_phone_v1 | trip_orders_product_array_v1
SABRE_CREATEBOOKING_PAYLOAD_STYLE=trip_orders_flight_offer_v1
# B33/B34: Sabre Trip Orders traditional booking — set agency/office phone (default wire agencyContactInfo; B34 styles use alternate keys). Required for production live booking when using Sabre traditional flight-details styles above.
SABRE_AGENCY_PHONE=
SABRE_AGENCY_PHONE_COUNTRY_CODE=PK
SABRE_AGENCY_PHONE_TYPE=AGENCY
# B37: LocationCode on traditional PNR phone-line compare styles (IATA-style).
SABRE_AGENCY_PHONE_LOCATION=LHE
# B36: Optional agency metadata for POS / camel agency blocks (inspect prints booleans only).
SABRE_AGENCY_NAME=
SABRE_AGENCY_CITY=
SABRE_AGENCY_COUNTRY=PK
SABRE_AGENCY_POS_PHONE_USE_TYPE=A
# B26: Omit Trip Orders wire `remarks` when false (default); true sends structured GENERAL/text rows (confirm against Sabre).
SABRE_CREATEBOOKING_SEND_REMARKS=false
# B38: compare-booking-endpoints matrix + traditional_pnr_create_passenger_name_record_v1 inspect (see .env.example).
# B61: Optional AirBook RetryRebook + RedisplayReservation on traditional CPNR wire (local/testing; default false).
SABRE_TRADITIONAL_CPNR_AIRBOOK_RETRY_REDISPLAY=false
SABRE_DOCUMENT_TYPE_PASSPORT_VALUE=PASSPORT
# B14/B21: Pre-booking revalidate before Trip Orders createBooking; explicit bypass flag for unusable revalidate responses.
SABRE_REVALIDATE_PATH=/v4/shop/flights/revalidate
SABRE_REVALIDATE_BEFORE_BOOKING=true
SABRE_ALLOW_CREATEBOOKING_WITHOUT_REVALIDATION=false
# Keep default in production unless Sabre certifies alternate shapes.
SABRE_REVALIDATE_PAYLOAD_STYLE=bfm_revalidate_v1
OTA_PRIVATE_DOCUMENTS_DIRECTORY=app/private
OTA_PDF_TEMP_DIRECTORY=app/private/tmp/pdf
OTA_BACKUP_DISK=local
OTA_BACKUP_PATH=backups

# Developer control panel (product owner / deployer only — not client platform admin)
OTA_DEVELOPER_CP_ENABLED=false

# Cloudflare Turnstile (public forms)
TURNSTILE_ENABLED=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
